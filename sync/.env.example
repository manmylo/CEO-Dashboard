# Copy to .env for LOCAL testing only (never commit .env).
# In GitHub Actions these live as repo Secrets instead.

SHOP_DOMAIN=gearevo.myshopify.com
SHOP_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOP_API_VERSION=2026-01
MONTHLY_TARGET=120000

# Firebase service account JSON as a single line (see README)
FIREBASE_SA={"type":"service_account", ... }

# EmailJS (optional — enable non-browser API in EmailJS settings first)
EMAILJS_SERVICE_ID=service_xxx
EMAILJS_TEMPLATE_ID=template_xxx
EMAILJS_PUBLIC_KEY=xxxxxxxx
EMAILJS_PRIVATE_KEY=xxxxxxxx
REPORT_TO=boss@gearevo.com

# Comma-separated list of emails allowed to view the dashboard. Written to
# the config/access Firestore doc on every sync run; firestore.rules checks
# membership against that doc instead of hardcoding emails (this repo is
# public — never put real emails directly in firestore.rules).
ALLOWED_EMAILS=you@example.com,director@example.com
